# ====================================
# MarketingOS — Dokploy Configuration
# ====================================

# Copy this file to .env and fill in your values

# ---- Server ----
PORT=3000
NODE_ENV=production

# ---- Database (PostgreSQL) ----
DB_HOST=mktos-pg
DB_PORT=5432
DB_NAME=mktos
DB_USER=mktos
DB_PASSWORD=change_this_in_production

# ---- JWT ----
JWT_SECRET=generate_a_secure_random_string_here
JWT_EXPIRES_IN=7d

# ---- CORS ----
CORS_ORIGIN=https://your-domain.com

# ---- Dokploy PostgreSQL ----
# If using Dokploy's managed PostgreSQL, these will be auto-injected
# DATABASE_URL=postgres://user:pass@host:5432/db
