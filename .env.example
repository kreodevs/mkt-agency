# Database (use DB_PASSWORD; DB_PASS is legacy alias in backend only)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mktos
DB_USER=mktos
DB_PASSWORD=change_me

# App
NODE_ENV=development
PORT=3000
# Host port when using docker-compose.yml (default 3001 avoids clash with local Nest)
# API_PUBLISH_PORT=3001
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=*

# Public API base URL (embedded form snippets)
API_PUBLIC_URL=http://localhost:3000/api/v1

# Redis (BullMQ workers)
REDIS_URL=redis://localhost:6379

# LLM: configurar proveedores y tareas en superadmin (/admin/llm-providers, /admin/llm-settings)
# Ya no se usan AI_API_URL, AI_API_KEY ni AI_MODEL en entorno.

# Hermes webhook (optional — notifies Hermes on proposal approve/reject)
# HERMES_WEBHOOK_URL=https://your-hermes-webhook.com/events

# S3-compatible storage (MinIO local / DO Spaces prod)
# MINIO_DATA_DIR=./data/minio
# S3_ENDPOINT=http://localhost:9000
# S3_PUBLIC_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=mkt-agency-assets
# S3_REGION=us-east-1
# STORAGE_LOCAL_PUBLIC_BASE=http://localhost:3000/uploads

# Custom domains (whitelabel)
DOMAIN_CNAME_TARGET=dashboard.mktagency.app
# DOMAIN_DNS_STUB=true

# Security alerts (T-007) — Slack Incoming Webhook
# SLACK_SECURITY_WEBHOOK_URL=https://hooks.slack.com/services/...
