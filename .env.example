# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mktos
DB_USER=mktos
DB_PASSWORD=change_me

# Auth
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=*

# Public API base URL (embedded form snippets)
API_PUBLIC_URL=http://localhost:3000/api/v1

# Redis (BullMQ workers)
REDIS_URL=redis://localhost:6379

# AI Provider (OpenAI-compatible)
# OpenRouter: https://openrouter.ai/api/v1
# LemonData: https://api.lemondata.ai/v1
AI_API_URL=https://openrouter.ai/api/v1
AI_API_KEY=sk-your-api-key-here
AI_MODEL=deepseek/deepseek-v4-flash

# Hermes webhook (optional — notifies Hermes on proposal approve/reject)
# HERMES_WEBHOOK_URL=https://your-hermes-webhook.com/events

# S3-compatible storage (MinIO local / DO Spaces prod)
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=agenteia-assets
# S3_REGION=us-east-1
# STORAGE_LOCAL_PUBLIC_BASE=http://localhost:3000/uploads

# Custom domains (whitelabel)
DOMAIN_CNAME_TARGET=dashboard.mktagency.app
# DOMAIN_DNS_STUB=true
