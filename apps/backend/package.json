    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/cqrs": "^10.2.8",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/typeorm": "^10.0.2",
    "argon2": "^0.41.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.79.1",
    "class-transformer": "^0.5.1",
